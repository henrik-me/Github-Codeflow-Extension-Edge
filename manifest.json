{
      "manifest_version": 3,
      "name": "Codeflow",
      "version": "1.0",
      "author" : "henrikm",
    
      "description": "Enables CodeFlow Integration for Github PR's.",
    
      "icons": {
        "16": "icons/icon-16x16.png",
        "48": "icons/icon-48x48.png",
        "128": "icons/icon-128x128.png"
      },
    
      "content_scripts": [
        {
          "matches": [ "*://*.github.com/*" ],
          "js": [ "codeflow.js" ],
          "run_at": "document_idle"
        }
      ]
    }
