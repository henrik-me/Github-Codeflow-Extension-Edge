{
      "manifest_version": 3,
      "name": "Codeflow",
      "version": "1.0",
      "author" : "henrikm",
    
      "description": "Enables CodeFlow Integration for Github PR's.",
    
      "icons": {
        "48": "icons/icon.png"
      },
    
      "content_scripts": [
        {
          "matches": [ "*://*.github.com/*/pull/*", "*://*.github.com/*/pulls*"],
          "js": [ "codeflow.js" ],
          "run_at": "document_idle"
        }
      ]
    }